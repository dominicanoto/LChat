<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.messenger.controller.ChatController">

    <left>

        <VBox spacing="10"
              prefWidth="250"
              style="-fx-padding: 10; -fx-background-color: #2b2d31;">

            <TextField fx:id="searchField"
                       promptText="Search by username..." />

            <ListView fx:id="dialogsList"
                      VBox.vgrow="ALWAYS" />

            <Label fx:id="emptyLabel"
                   text="No dialogs yet"
                   style="-fx-text-fill: gray;" />

        </VBox>

    </left>

    <center>

        <VBox spacing="10"
              style="-fx-padding: 10;">

            <VBox spacing="2">

                <Label fx:id="nameLabel"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;" />

                <Label fx:id="usernameLabel"
                       style="-fx-text-fill: gray;" />

                <Label fx:id="statusLabel"
                       style="-fx-text-fill: green;" />

            </VBox>

            <TextArea fx:id="chatArea"
                      editable="false"
                      wrapText="true"
                      VBox.vgrow="ALWAYS" />

            <HBox spacing="10">

                <TextField fx:id="messageField"
                           promptText="Type a message..."
                           HBox.hgrow="ALWAYS" />

                <Button fx:id="sendButton"
                        text="Send" />

            </HBox>

        </VBox>

    </center>

</BorderPane>