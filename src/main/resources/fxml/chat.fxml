<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.messenger.controller.ChatController"
            prefWidth="920"
            prefHeight="620"
            stylesheets="@../css/style.css"
            styleClass="chat-root">

    <left>
        <VBox spacing="10"
              prefWidth="300"
              styleClass="dialog-sidebar">

            <padding>
                <Insets top="14" right="12" bottom="14" left="12"/>
            </padding>

            <HBox alignment="CENTER_LEFT"
                  spacing="8">

                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="currentNameLabel"
                           text="User"
                           styleClass="current-name"/>

                    <HBox alignment="CENTER_LEFT"
                          spacing="6">
                        <Label text="●"
                               styleClass="online-dot"/>

                        <Label fx:id="currentUsernameLabel"
                               text="@username"
                               styleClass="current-username"/>
                    </HBox>
                </VBox>

                <Button fx:id="themeButton"
                        text="Dark"
                        styleClass="icon-button"/>

            </HBox>

            <HBox spacing="8">
                <Button fx:id="editNameButton"
                        text="Edit name"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        styleClass="sidebar-button"/>

                <Button fx:id="logoutButton"
                        text="Log out"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        styleClass="sidebar-button"/>
            </HBox>

            <TextField fx:id="searchField"
                       promptText="Search by username..."
                       styleClass="search-field"/>

            <ListView fx:id="dialogsList"
                      VBox.vgrow="ALWAYS"
                      styleClass="dialogs-list"/>

            <Label fx:id="emptyLabel"
                   text="No dialogs yet"
                   styleClass="empty-label"/>

        </VBox>
    </left>

    <center>
        <BorderPane styleClass="chat-pane">

            <top>
                <VBox spacing="2"
                      styleClass="chat-header">

                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>

                    <Label fx:id="nameLabel"
                           text="Select a chat"
                           styleClass="chat-name"/>

                    <Label fx:id="usernameLabel"
                           styleClass="chat-username"/>

                    <Label fx:id="statusLabel"
                           styleClass="chat-status"/>

                </VBox>
            </top>

            <center>
                <TextArea fx:id="chatArea"
                          editable="false"
                          wrapText="true"
                          styleClass="chat-area"/>
            </center>

            <bottom>
                <HBox spacing="10"
                      styleClass="message-bar">

                    <padding>
                        <Insets top="12" right="16" bottom="14" left="16"/>
                    </padding>

                    <TextField fx:id="messageField"
                               promptText="Type a message..."
                               HBox.hgrow="ALWAYS"
                               styleClass="message-field"/>

                    <Button fx:id="sendButton"
                            text="Send"
                            styleClass="send-button"/>

                </HBox>
            </bottom>

        </BorderPane>
    </center>

</BorderPane>
