<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.messenger.controller.RegisterController"
            prefWidth="430"
            prefHeight="500"
            stylesheets="@../css/style.css"
            styleClass="auth-root">

    <top>
        <HBox alignment="CENTER_RIGHT"
              styleClass="auth-topbar">
            <padding>
                <Insets top="14" right="16" bottom="0" left="16"/>
            </padding>

            <Button fx:id="themeButton"
                    text="Dark"
                    styleClass="ghost-button"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              spacing="14"
              maxWidth="330"
              styleClass="auth-card">

            <padding>
                <Insets top="28" right="36" bottom="34" left="36"/>
            </padding>

            <Label text="Create Account"
                   styleClass="auth-title"/>

            <Label text="Name can be changed later"
                   styleClass="auth-subtitle"/>

            <TextField fx:id="nameField"
                       promptText="Display name"/>

            <TextField fx:id="usernameField"
                       promptText="Username"/>

            <PasswordField fx:id="passwordField"
                           promptText="Password"/>

            <Button text="Create Account"
                    fx:id="createButton"
                    styleClass="primary-button"/>

            <Button text="Back to login"
                    fx:id="backButton"
                    styleClass="link-button"/>

        </VBox>
    </center>

</BorderPane>
